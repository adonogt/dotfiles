; 侘び寂び — dunst config
; harmonia com o polybar

[global]
    monitor = 0
    follow = none
    width = (160, 280)
    height = 160
    origin = top-right
    offset = 12x28

    notification_limit = 3

    # Progress bar — linha fina, sem frame
    progress_bar = true
    progress_bar_height = 1
    progress_bar_frame_width = 0
    progress_bar_min_width = 140
    progress_bar_max_width = 260
    progress_bar_corner_radius = 0
    progress_bar_color = "#7a6a60"

    # Espaço — 間
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 0
    gap_size = 6

    # Frame — apenas sugestão
    frame_width = 1
    separator_color = frame
    corner_radius = 0
    transparency = 25

    # Tipografia — mesma do polybar
    font = PlemolJP Console NF Bold 9
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    ellipsize = end
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = true
    show_indicators = no

    # Sem ícones
    icon_position = off

    # Mouse
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all


[urgency_low]
    ; sussurro — quase invisível
    background = "#cc0d0d0d"
    foreground = "#7a6a60"
    frame_color = "#661a1a1a"
    timeout = 3

[urgency_normal]
    ; presença serena — bege envelhecido do polybar
    background = "#cc0d0d0d"
    foreground = "#d4c4b0"
    frame_color = "#662a2016"
    timeout = 4

[urgency_critical]
    ; alerta contido — terracota do polybar
    background = "#cc0d0d0d"
    foreground = "#e8825a"
    frame_color = "#663a1a0a"
    timeout = 0

